---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MediaFrame from '../../components/MediaFrame.astro';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return works.map((work) => ({ params: { slug: work.id }, props: { work } }));
}

const { work } = Astro.props;
const { Content } = await render(work);
const works = (await getCollection('works')).sort((a, b) => a.data.order - b.data.order);
const currentIndex = works.findIndex((item) => item.id === work.id);
const nextWork = works[(currentIndex + 1) % works.length];
---

<BaseLayout title={work.data.title} description={`${work.data.title}, ${work.data.focus.join(', ')}`} active="works">
  <article class="case-page">
    <aside class="case-aside reveal">
      <a class="back-link" href={withBase('/archive')}>返回档案 / Archive</a>
      <div>
        <h1>{work.data.title}</h1>
        <p>{work.data.focus.join(' / ')}</p>
      </div>
      <dl class="meta-list">
        <div>
          <dt>年份 / Year</dt>
          <dd>{work.data.year}</dd>
        </div>
        <div>
          <dt>职责 / Role</dt>
          <dd>{work.data.role}</dd>
        </div>
        {work.data.client && (
          <div>
            <dt>客户 / Client</dt>
            <dd>{work.data.client}</dd>
          </div>
        )}
        <div>
          <dt>状态 / Status</dt>
          <dd>{work.data.status}</dd>
        </div>
      </dl>
      {work.data.externalUrl && <a class="text-link" href={work.data.externalUrl} target="_blank" rel="noreferrer">访问项目 / Visit project</a>}
    </aside>

    <div class="case-content reveal">
      <div class="case-copy">
        <Content />
      </div>
      <div class="case-gallery">
        {work.data.gallery.map((item, index) => (
          <MediaFrame
            src={item.image}
            alt={`${work.data.title} ${index + 1}`}
            caption={item.caption}
            index={String(index + 1).padStart(2, '0')}
          />
        ))}
      </div>
    </div>
  </article>

  <section class="next-work">
    <span>下一个作品 / Next Work</span>
    <a href={withBase(`/work/${nextWork.id}`)}>{nextWork.data.title}</a>
  </section>
</BaseLayout>
