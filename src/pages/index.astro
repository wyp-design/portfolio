---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
import portfolioData from '../data/portfolioCategories.json';
import { withBase } from '../lib/url';

const categories = portfolioData.categories;
const first = categories[0];
---

<BaseLayout active="works">
  <section class="home-stage">
    <div class="home-stage__identity reveal">
      <h1>{site.name}</h1>
      <p>{site.role}</p>
    </div>

    <div class="home-stage__issue reveal">
      <span>第 001 期 / 作品集 2026</span>
      <span>Ref. ARCHIVE-PORTFOLIO</span>
    </div>

    <div class="home-stage__mark reveal" aria-hidden="true">
      <span>WYP</span>
    </div>

    <div class="home-stage__preview reveal" data-home-preview>
      <img
        src={withBase(first.cover)}
        alt={`${first.title} cover`}
        data-preview-image
      />
    </div>

    <div class="home-stage__works reveal category-index" data-work-table>
      {categories.map((category, index) => (
        <a
          class="category-index__row"
          href={withBase(`/category/${category.slug}`)}
          data-preview={withBase(category.cover)}
        >
          <span class="category-index__id">CAT_{String(index + 1).padStart(2, '0')}</span>
          <span class="category-index__title">{category.title}</span>
          <span class="category-index__en">{category.titleEn}</span>
          <span class="category-index__summary">{category.summary}</span>
        </a>
      ))}
    </div>

    <div class="home-stage__footer">
      <span>{site.location}</span>
      <span>精选作品与创作手记 / Selected works and notes</span>
      <span>滚动 000% / Scroll</span>
    </div>
  </section>
</BaseLayout>
