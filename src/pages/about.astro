---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---

<BaseLayout title="About" active="about">
  <section class="about-page page-shell">
    <div class="about-page__mark reveal" aria-hidden="true">
      <span>95</span>
    </div>
    <div class="about-page__content reveal">
      <section class="content-block">
        <h1>{site.name}</h1>
        <p>{site.role}</p>
      </section>

      <section class="content-block">
        <h2>Biography</h2>
        {site.bio.map((paragraph) => <p>{paragraph}</p>)}
      </section>

      <section class="content-block content-block--split">
        <h2>Capabilities</h2>
        <ul>
          {site.capabilities.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section class="content-block content-block--split">
        <h2>Contact & Inquiries</h2>
        <a class="text-link" href={`mailto:${site.email}`}>{site.email}</a>
      </section>

      <section class="content-block content-block--split">
        <h2>Socials</h2>
        <ul>
          {site.socials.map((social) => (
            <li><a href={social.url} target="_blank" rel="noreferrer">{social.label}</a></li>
          ))}
        </ul>
      </section>

      <footer class="about-footer">
        <span>{site.location}</span>
        <span>{site.timezone}</span>
        <span>2026</span>
      </footer>
    </div>
  </section>
</BaseLayout>
