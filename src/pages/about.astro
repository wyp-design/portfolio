---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---

<BaseLayout title="关于 About" active="about">
  <section class="about-page page-shell">
    <div class="about-page__mark reveal" aria-hidden="true">
      <span>YP</span>
    </div>
    <div class="about-page__content reveal">
      <section class="content-block">
        <h1>{site.name}</h1>
        <p>{site.role}</p>
      </section>

      <section class="content-block">
        <h2>简介 / Biography</h2>
        {site.bio.map((paragraph) => <p>{paragraph}</p>)}
      </section>

      <section class="content-block content-block--split">
        <h2>能力 / Capabilities</h2>
        <ul>
          {site.capabilities.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section class="content-block content-block--split">
        <h2>联系 / Contact</h2>
        <div class="contact-list">
          <a class="text-link" href={`mailto:${site.email}`}>{site.email}</a>
          <a class="text-link" href={`tel:${site.phone}`}>{site.phone}</a>
        </div>
      </section>

      <section class="content-block content-block--split">
        <h2>经历 / Experience</h2>
        <div class="timeline-list">
          {site.experience.map((item) => (
            <article class="timeline-item">
              <div>
                <h3>{item.company}</h3>
                <p>{item.role} / {item.period}</p>
              </div>
              <ul>
                {item.summary.map((line) => <li>{line}</li>)}
              </ul>
              {item.url && <a class="text-link" href={item.url} target="_blank" rel="noreferrer">项目链接 / Visit</a>}
            </article>
          ))}
        </div>
      </section>

      <section class="content-block content-block--split">
        <h2>教育 / Education</h2>
        <div class="timeline-list timeline-list--compact">
          {site.education.map((item) => (
            <article class="timeline-item">
              <h3>{item.school}</h3>
              <p>{item.program} / {item.detail}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="content-block content-block--split">
        <h2>链接 / Links</h2>
        <ul>
          {site.socials.map((social) => (
            <li><a href={social.url} target="_blank" rel="noreferrer">{social.label}</a></li>
          ))}
        </ul>
      </section>

      <footer class="about-footer">
        <span>{site.location}</span>
        <span>{site.timezone}</span>
        <span>2026</span>
      </footer>
    </div>
  </section>
</BaseLayout>
