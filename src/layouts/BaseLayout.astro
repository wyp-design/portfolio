---
import '../styles/global.css';
import site from '../data/site.json';
import { withBase } from '../lib/url';

interface Props {
  title?: string;
  description?: string;
  active?: 'works' | 'archive' | 'blog' | 'about';
}

const {
  title = site.seo.title,
  description = site.seo.description,
  active = 'works'
} = Astro.props;
const pageTitle = title === site.seo.title ? title : `${title} · ${site.name}`;
const nav = [
  { label: 'Works', href: '/', key: 'works' },
  { label: 'Archive', href: '/archive', key: 'archive' },
  { label: 'Blog', href: '/blog', key: 'blog' },
  { label: 'About', href: '/about', key: 'about' }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta name="theme-color" content="#070304" />
  </head>
  <body data-page={active}>
    <div class="site-grid" aria-hidden="true">
      {Array.from({ length: 12 }).map(() => <span />)}
    </div>
    <header class="site-header">
      <button class="grid-toggle" type="button" data-grid-toggle aria-label="Toggle grid">
        Dimensions
      </button>
      <nav class="site-nav" aria-label="Primary navigation">
        {nav.map((item, index) => (
          <a
            class:list={['site-nav__link', active === item.key && 'is-active']}
            href={withBase(item.href)}
          >
            {item.label}{index < nav.length - 1 ? ',' : ''}
          </a>
        ))}
      </nav>
      <button class="availability" type="button" data-copy-email={site.email}>
        <span class="availability__mark" aria-hidden="true"></span>
        <span class="availability__status">{site.availability}</span>
        <span class="availability__copy" data-copy-label>Copy email?</span>
      </button>
    </header>

    <main>
      <slot />
    </main>

    <div class="scroll-progress" aria-hidden="true">
      <span data-scroll-progress></span>
    </div>
    <script is:inline>
      (() => {
        window.__portfolioReady = true;
        const body = document.body;

        const progress = document.querySelector('[data-scroll-progress]');
        const updateProgress = () => {
          if (!progress) return;
          const max = document.documentElement.scrollHeight - window.innerHeight;
          const ratio = max > 0 ? window.scrollY / max : 0;
          progress.style.width = `${Math.min(1, Math.max(0, ratio)) * 100}%`;
        };
        updateProgress();
        window.addEventListener('scroll', updateProgress, { passive: true });
        window.addEventListener('resize', updateProgress);

        document.querySelector('[data-grid-toggle]')?.addEventListener('click', () => {
          body.classList.toggle('is-grid-visible');
        });

        document.querySelectorAll('[data-copy-email]').forEach((button) => {
          const label = button.querySelector('[data-copy-label]');
          button.addEventListener('click', async () => {
            const email = button.getAttribute('data-copy-email');
            try {
              await navigator.clipboard.writeText(email);
              button.classList.add('is-copied');
              if (label) label.textContent = 'Email copied!';
              window.setTimeout(() => {
                button.classList.remove('is-copied');
                if (label) label.textContent = 'Copy email?';
              }, 1600);
            } catch {
              window.location.href = `mailto:${email}`;
            }
          });
        });

        document.querySelectorAll('[data-work-table]').forEach((table) => {
          const previewRoot =
            document.querySelector('[data-home-preview]') ||
            document.querySelector('[data-floating-preview]');
          const previewImage = previewRoot?.querySelector('[data-preview-image]');
          const rows = table.querySelectorAll('[data-preview]');
          rows.forEach((row) => {
            row.addEventListener('mouseenter', () => {
              rows.forEach((item) => item.classList.remove('is-active'));
              row.classList.add('is-active');
              const src = row.getAttribute('data-preview');
              if (previewImage && src) previewImage.src = src;
            });
          });
        });

        document.querySelectorAll('[data-view-button]').forEach((button) => {
          button.addEventListener('click', () => {
            const view = button.getAttribute('data-view-button');
            document.querySelectorAll('[data-view-button]').forEach((item) => {
              item.classList.toggle('is-active', item === button);
            });
            document.querySelectorAll('[data-view-panel]').forEach((panel) => {
              panel.hidden = panel.getAttribute('data-view-panel') !== view;
            });
          });
        });
      })();
    </script>
  </body>
</html>
